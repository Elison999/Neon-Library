    function Library:RefreshTheme()
        local T = Library.CurrentTheme
        CreateTween(MainFrame, {BackgroundColor3 = T.Main, BackgroundTransparency = Library.Settings.Transparency and 0.45 or 0}, 0.3)
        CreateTween(Topbar, {BackgroundColor3 = T.Top}, 0.3)
        CreateTween(FixB, {BackgroundColor3 = T.Top}, 0.3)
        CreateTween(SearchBar, {BackgroundColor3 = T.Element}, 0.3)
        CreateTween(MainStroke, {Color = T.GradA or T.Glow}, 0.3)
        CreateTween(SBStroke, {Color = T.GradA or T.Accent}, 0.3)
        CreateTween(Divider, {BackgroundColor3 = T.GradA or Color3.fromRGB(80,80,80)}, 0.3)
        CreateTween(OBStroke, {Color = T.GradA or T.Accent}, 0.3)

        -- Update gradients
        TopGradient.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, T.GradA or T.Accent),
            ColorSequenceKeypoint.new(1, T.GradB or T.Glow)
        }
        FixBGrad.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, T.GradA or T.Accent),
            ColorSequenceKeypoint.new(1, T.GradB or T.Glow)
        }

        TabContainer.ScrollBarImageColor3 = T.GradA or T.Accent
        TitleLbl.TextColor3 = Color3.fromRGB(255,255,255)

        for _, obj in pairs(TabContainer:GetChildren()) do
            if obj:IsA("TextButton") then
                if obj.BackgroundTransparency < 0.5 then
                    obj.TextColor3 = Color3.fromRGB(255,255,255)
                    local g = obj:FindFirstChildOfClass("UIGradient")
                    if g then
                        g.Color = ColorSequence.new{
                            ColorSequenceKeypoint.new(0, T.GradA or T.Accent),
                            ColorSequenceKeypoint.new(1, T.GradB or T.Glow)
                        }
                    end
                else
                    obj.TextColor3 = Color3.fromRGB(140,140,140)
                end
            end
        end

        for _, page in pairs(PagesFolder:GetChildren()) do
            if page:IsA("ScrollingFrame") then
                for _, elem in pairs(page:GetChildren()) do
                    if elem:IsA("Frame") and elem.Name == "ElementFrame" then
                        CreateTween(elem, {BackgroundColor3 = T.Element}, 0.3)
                        local txt = elem:FindFirstChildOfClass("TextLabel")
                        if txt then txt.TextColor3 = T.Text end
                        local btn = elem:FindFirstChildOfClass("TextButton")
                        if btn and btn.Text ~= "" then btn.TextColor3 = T.Text end
                        if elem:FindFirstChild("Scroll") then
                            for _, subElem in pairs(elem.Scroll:GetChildren()) do
                                if subElem:IsA("TextButton") then
                                    subElem.BackgroundColor3 = Color3.fromRGB(30,30,35)
                                end
                            end
                        end
                    elseif elem:IsA("TextLabel") and elem.Name == "SectionLabel" then
                        elem.TextColor3 = T.GradA or T.Accent
                        local line = elem:FindFirstChild("Line")
                        if line then
                            local lg = line:FindFirstChildOfClass("UIGradient")
                            if lg then
                                lg.Color = ColorSequence.new{
                                    ColorSequenceKeypoint.new(0, T.GradA or T.Accent),
                                    ColorSequenceKeypoint.new(0.5, T.GradB or T.Glow),
                                    ColorSequenceKeypoint.new(1, T.GradA or T.Accent)
                                }
                            else
                                line.BackgroundColor3 = T.GradA or T.Accent
                            end
                        end
                    end
                end
            end
        end
    end

