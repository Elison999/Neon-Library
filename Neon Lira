            local RightLine2 = Instance.new("Frame")
            RightLine2.Parent = SepFrame
            RightLine2.BackgroundColor3 = Library.CurrentTheme.Accent
            RightLine2.BackgroundTransparency = 0.65
            RightLine2.BorderSizePixel = 0
            RightLine2.AnchorPoint = Vector2.new(1,0.5)
            RightLine2.Position = UDim2.new(1,0,0.5,0)
            if text and text ~= "" then
                local SepLbl = Instance.new("TextLabel")
                SepLbl.Parent = SepFrame
                SepLbl.BackgroundTransparency = 1
                SepLbl.AnchorPoint = Vector2.new(0.5,0.5)
                SepLbl.Position = UDim2.new(0.5,0,0.5,0)
                SepLbl.Size = UDim2.new(0,100,1,0)
                SepLbl.Font = Enum.Font.GothamBold
                SepLbl.Text = text
                SepLbl.TextColor3 = Library.CurrentTheme.Accent
                SepLbl.TextSize = 11
                SepLbl.TextTransparency = 0.25
                LeftLine2.Size  = UDim2.new(0.5,-56,0,1)
                RightLine2.Size = UDim2.new(0.5,-56,0,1)
            else
                LeftLine2.Size  = UDim2.new(1,0,0,1)
                RightLine2.Size = UDim2.new(0,0,0,1)
            end
            return SepFrame
        end

        return Tab
    end

    -- ── AddConfig (Aba de Configuração) ────────────────────────
    function Window:AddConfig()
        local ConfigTab = Window:Tab(Library:GetText("ConfigTab"))

        ConfigTab:Paragraph(Library:GetText("ScriptsTitle"))
        ConfigTab:Button("Infinite Yield", function()
            loadstring(game:HttpGet('https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source'))()
            Library:Notification({Title="Script", Content=Library:GetText("ExecScript").."Infinite Yield", Type="success"})
        end, "Carrega o executor de comandos Infinite Yield")

        ConfigTab:Button("Tiger X", function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/balintTheDevX/Tiger-X-V3/main/Tiger%20X%20V3.5%20Fixed"))()
            Library:Notification({Title="Script", Content=Library:GetText("ExecScript").."Tiger X", Type="success"})
        end, "Carrega o Tiger X V3.5")

        ConfigTab:Separator()
        ConfigTab:Paragraph(Library:GetText("ConfigTab"))

        local LangDropLbl = ConfigTab:Dropdown(Library:GetText("LangDrop"), {"English","Portuguese"}, function(Selected)
            Library.Settings.Language = Selected
            Library:Notification({Title="Language", Content="Language changed to "..Selected, Type="info"})
        end, "Muda o idioma da interface")

        local TransToggle, TransLabel = ConfigTab:Toggle(Library:GetText("TransToggle"), false, function(Val)
            Library.Settings.Transparency = Val
            Library:RefreshTheme()
        end, "Torna o fundo da janela semi-transparente")

        local PulseToggle, PulseLabel = ConfigTab:Toggle(Library:GetText("PulseToggle"), Library.Settings.PulseGlow, function(Val)
            Library.Settings.PulseGlow = Val
        end, "Ativa o efeito de glow pulsante na borda")

        local ToolTipToggle, ToolTipLabel = ConfigTab:Toggle(Library:GetText("TooltipToggle"), Library.Settings.Tooltips, function(Val)
            Library.Settings.Tooltips = Val
        end, "Mostra dicas ao passar o mouse nos elementos")

        ConfigTab:Separator("Temas")

        local ThemeNames = {}
        for n,_ in pairs(Library.Themes) do table.insert(ThemeNames,n) end
        table.sort(ThemeNames)

        local ThemeDropLbl = ConfigTab:Dropdown(Library:GetText("ThemeDrop"), ThemeNames, function(Selected)
            Library:SetTheme(Selected)
            Library:Toast("Tema: "..Selected)
        end, "Escolha o tema visual da interface")

        ConfigTab:Separator()

        local SaveBtn = ConfigTab:Button(Library:GetText("SaveBtn"), function()
            SaveConfig()
            Library:Notification({Title="Config", Content=Library:GetText("SaveMsg"), Type="success"})
        end, "Salva as configurações atuais em arquivo")

        local LoadBtn = ConfigTab:Button(Library:GetText("LoadBtn"), function()
            if LoadConfig() then
                Library:Notification({Title="Config", Content=Library:GetText("LoadMsg"), Type="info"})
            else
                Library:Notification({Title="Error", Content=Library:GetText("LoadErr"), Type="error"})
            end
        end, "Carrega as configurações salvas")

        -- Loop de atualização de texto (tradução em tempo real)
        task.spawn(function()
            while task.wait(0.5) do
                if LangDropLbl  then LangDropLbl.Set  and nil or (LangDropLbl.Text and function() end)() end
                if SearchBar    then SearchBar.PlaceholderText = Library:GetText("SearchPlace") end
            end
        end)
    end

    return Window
end

return Library
