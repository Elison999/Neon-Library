                    CreateTween(v, {BackgroundTransparency = 1, TextColor3 = Color3.fromRGB(140,140,155)}, 0.2)
                end
            end
        end
        for _,v in pairs(PagesFolder:GetChildren()) do
            if v:IsA("ScrollingFrame") then v.Visible = (v.Name == PageName) end
        end
    end

