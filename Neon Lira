local function MakeRipple(frame, relX, relY, color)
    local ok, _ = pcall(function()
        local Ripple = Instance.new("Frame")
        Ripple.Name = "Ripple"
        Ripple.BackgroundColor3 = color or Color3.fromRGB(255,255,255)
        Ripple.BackgroundTransparency = 0.7
        Ripple.AnchorPoint = Vector2.new(0.5, 0.5)
        Ripple.Position = UDim2.new(0, relX, 0, relY)
        Ripple.Size = UDim2.new(0, 0, 0, 0)
        Ripple.ZIndex = 20
        Ripple.Parent = frame
        local RC = Instance.new("UICorner")
        RC.CornerRadius = UDim.new(1, 0)
        RC.Parent = Ripple
        local maxSize = math.max(frame.AbsoluteSize.X, frame.AbsoluteSize.Y) * 2.8
        local t = TweenService:Create(Ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, maxSize, 0, maxSize),
            BackgroundTransparency = 1
        })
        t:Play()
        t.Completed:Connect(function() Ripple:Destroy() end)
    end)
end

local function ProtectGui(gui)
    if syn and syn.protect_gui then
        syn.protect_gui(gui)
        gui.Parent = CoreGui
    elseif gethui then
        gui.Parent = gethui()
    else
        gui.Parent = CoreGui
    end
end

