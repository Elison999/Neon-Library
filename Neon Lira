                    CreateTween(DFr, {Size = UDim2.new(1,0,0,136)}, 0.2)
                    CreateTween(Arrow, {Rotation = 180}, 0.2)
                else
                    CreateTween(DFr, {Size = UDim2.new(1,0,0,32)}, 0.2)
                    CreateTween(Arrow, {Rotation = 0}, 0.2)
                end
            end)
            
            local ReturnObj = {
                Set = function(self, val)
                    if type(val) == "table" then
                        Selected = val
                        Library.Flags[text] = Selected
                        UpdateText()
                        RefreshList()
                    end
                end,
                Refresh = function(self, newlist)
                    BuildItems(newlist)
                end
            }
            Library.Elements[text] = ReturnObj
            table.insert(Library.SearchIndex, {Name = text, Tab = name, Instance = DFr})
            UpdateText()
            return ReturnObj 
