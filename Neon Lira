                local count = 0
                for _ in pairs(Selected) do count = count + 1 end
                if count == 0 then
                    DL.Text = text .. " (".. Library:GetText("NoBind") ..")"
                else
                    DL.Text = text .. " (".. Library:GetText("MultiSelect") .. count .. ")"
                end
            end

            local function IsSelected(item)
                for _, v in pairs(Selected) do
                    if v == item then return true end
                end
                return false
            end
            
            local function RefreshList()
                for _, obj in pairs(Scroll:GetChildren()) do
                    if obj:IsA("TextButton") then
                        if IsSelected(obj.Text) then
                            obj.TextColor3 = Library.CurrentTheme.GradA or Library.CurrentTheme.Accent
                        else
