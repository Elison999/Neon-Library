                if v.Text:gsub("%s+%[.+%]","") == PageName or v.Name == PageName then
                    CreateTween(v, {BackgroundTransparency = 0.85, TextColor3 = Library.CurrentTheme.Text}, 0.2)
                    MoveTabIndicator(v)
